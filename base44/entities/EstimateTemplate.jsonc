{
  "name": "EstimateTemplate",
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "title": "Nome Template"
    },
    "estimate_type": {
      "type": "string",
      "title": "Tipo Preventivo",
      "enum": [
        "Bathroom",
        "Full Home",
        "Electrical System",
        "Networking",
        "Security",
        "Roofing",
        "Maintenance",
        "Other"
      ]
    },
    "quality_level": {
      "type": "string",
      "title": "Livello Qualit\u00e0",
      "enum": [
        "Essential",
        "Smart",
        "Intelligence"
      ]
    },
    "property_types": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Tipi Propriet\u00e0 Compatibili"
    },
    "scope_summary_template": {
      "type": "string",
      "title": "Template Riepilogo Progetto"
    },
    "included_works_template": {
      "type": "string",
      "title": "Template Lavori Inclusi"
    },
    "excluded_works_template": {
      "type": "string",
      "title": "Template Lavori Esclusi"
    },
    "assumptions_template": {
      "type": "string",
      "title": "Template Assunzioni"
    },
    "timeline_template": {
      "type": "string",
      "title": "Template Tempistiche"
    },
    "payment_terms": {
      "type": "string",
      "title": "Condizioni di Pagamento"
    },
    "warranty_notes": {
      "type": "string",
      "title": "Note Garanzia"
    },
    "estimated_duration": {
      "type": "string",
      "title": "Durata Stimata"
    },
    "is_active": {
      "type": "boolean",
      "title": "Attivo",
      "default": true
    }
  },
  "required": [
    "name",
    "estimate_type",
    "quality_level"
  ]
}