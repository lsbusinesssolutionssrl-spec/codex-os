{
  "name": "TenantMembership",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "title": "User ID"
    },
    "user_email": {
      "type": "string",
      "title": "User Email (for invited users without account)"
    },
    "tenant_id": {
      "type": "string",
      "title": "Tenant ID (Company)"
    },
    "tenant_role": {
      "type": "string",
      "title": "Tenant Role",
      "enum": [
        "tenant_admin",
        "project_manager",
        "technician",
        "sales",
        "viewer"
      ]
    },
    "membership_type": {
      "type": "string",
      "title": "Membership Type",
      "enum": [
        "customer_member",
        "internal_support",
        "platform_impersonation",
        "system"
      ],
      "default": "customer_member"
    },
    "status": {
      "type": "string",
      "title": "Membership Status",
      "enum": [
        "invited",
        "pending",
        "active",
        "suspended",
        "removed"
      ],
      "default": "pending"
    },
    "invited_by": {
      "type": "string",
      "title": "Invited By (User Email)"
    },
    "invited_at": {
      "type": "string",
      "title": "Invited At"
    },
    "joined_at": {
      "type": "string",
      "title": "Joined At"
    },
    "permissions": {
      "type": "object",
      "title": "Permissions",
      "properties": {
        "can_create_projects": {
          "type": "boolean",
          "default": false
        },
        "can_create_estimates": {
          "type": "boolean",
          "default": false
        },
        "can_view_financials": {
          "type": "boolean",
          "default": false
        },
        "can_manage_team": {
          "type": "boolean",
          "default": false
        },
        "can_access_api": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "default_workspace": {
      "type": "string",
      "title": "Default Workspace",
      "enum": [
        "executive",
        "operations",
        "sales",
        "financial",
        "guardian",
        "technician"
      ],
      "default": "operations"
    },
    "language": {
      "type": "string",
      "title": "Language",
      "default": "it"
    },
    "is_primary": {
      "type": "boolean",
      "title": "Is Primary Membership",
      "default": false
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    }
  },
  "required": [
    "tenant_id",
    "tenant_role"
  ]
}