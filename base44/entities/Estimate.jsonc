{
  "name": "Estimate",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "title": "Company"
    },
    "title": {
      "type": "string",
      "title": "Title"
    },
    "client_id": {
      "type": "string",
      "title": "Client"
    },
    "property_id": {
      "type": "string",
      "title": "Property"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "Draft",
        "To Review",
        "Sent",
        "Accepted",
        "Rejected",
        "Expired",
        "Converted to Project",
        "Archived"
      ],
      "default": "Draft"
    },
    "estimate_type": {
      "type": "string",
      "title": "Type",
      "enum": [
        "Bathroom",
        "Full Home",
        "Electrical System",
        "Networking",
        "Security",
        "Roofing",
        "Maintenance",
        "Other"
      ]
    },
    "quality_level": {
      "type": "string",
      "title": "Quality Level",
      "enum": [
        "Essential",
        "Smart",
        "Intelligence"
      ]
    },
    "square_meters": {
      "type": "number",
      "title": "Superficie (mq)"
    },
    "number_of_bathrooms": {
      "type": "number",
      "title": "Numero Bagni"
    },
    "number_of_rooms": {
      "type": "number",
      "title": "Numero Stanze"
    },
    "property_type": {
      "type": "string",
      "title": "Tipo Propriet\u00e0",
      "enum": [
        "Apartment",
        "Villa",
        "Office",
        "Industrial Building",
        "Commercial Space"
      ]
    },
    "location": {
      "type": "string",
      "title": "Localit\u00e0"
    },
    "urgency": {
      "type": "string",
      "title": "Urgenza",
      "enum": [
        "Standard",
        "Urgent"
      ],
      "default": "Standard"
    },
    "revenue": {
      "type": "number",
      "title": "Estimated Revenue (\u20ac)"
    },
    "material_cost": {
      "type": "number",
      "title": "Material Cost (\u20ac)"
    },
    "labor_cost": {
      "type": "number",
      "title": "Labor Cost (\u20ac)"
    },
    "equipment_cost": {
      "type": "number",
      "title": "Equipment Cost (\u20ac)"
    },
    "subcontractor_cost": {
      "type": "number",
      "title": "Subcontractor Cost (\u20ac)"
    },
    "other_costs": {
      "type": "number",
      "title": "Other Costs (\u20ac)"
    },
    "total_costs": {
      "type": "number",
      "title": "Total Costs (\u20ac)"
    },
    "gross_margin": {
      "type": "number",
      "title": "Gross Margin (\u20ac)"
    },
    "gross_margin_pct": {
      "type": "number",
      "title": "Gross Margin %"
    },
    "estimated_duration": {
      "type": "string",
      "title": "Estimated Duration"
    },
    "project_summary": {
      "type": "string",
      "title": "Project Summary"
    },
    "included_works": {
      "type": "string",
      "title": "Included Works"
    },
    "excluded_works": {
      "type": "string",
      "title": "Excluded Works"
    },
    "assumptions": {
      "type": "string",
      "title": "Assumptions"
    },
    "payment_terms": {
      "type": "string",
      "title": "Payment Terms"
    },
    "warranty_notes": {
      "type": "string",
      "title": "Warranty Notes"
    },
    "follow_up_date": {
      "type": "string",
      "title": "Follow-up Date"
    },
    "expiry_date": {
      "type": "string",
      "title": "Expiry Date"
    },
    "rejection_reason": {
      "type": "string",
      "title": "Rejection Reason",
      "enum": [
        "Price too high",
        "Timing",
        "Chose another company",
        "Project postponed",
        "Other"
      ]
    },
    "rejection_notes": {
      "type": "string",
      "title": "Rejection Notes"
    },
    "client_comments": {
      "type": "string",
      "title": "Client Comments"
    },
    "notes": {
      "type": "string",
      "title": "Internal Notes"
    },
    "signature_url": {
      "type": "string",
      "title": "Client Signature"
    },
    "signed_at": {
      "type": "string",
      "title": "Signed At"
    },
    "survey_photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Survey Photos"
    }
  },
  "required": [
    "title",
    "client_id"
  ]
}