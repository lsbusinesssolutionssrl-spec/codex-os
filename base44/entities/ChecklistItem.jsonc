{
  "name": "ChecklistItem",
  "type": "object",
  "properties": {
    "title": {
      "type": "string",
      "title": "Title"
    },
    "description": {
      "type": "string",
      "title": "Description"
    },
    "project_id": {
      "type": "string",
      "title": "Project"
    },
    "category": {
      "type": "string",
      "title": "Category",
      "enum": [
        "Bathroom",
        "Full Home",
        "Electrical",
        "Networking",
        "Security",
        "Roofing",
        "Handover"
      ]
    },
    "assigned_person": {
      "type": "string",
      "title": "Assigned Person"
    },
    "due_date": {
      "type": "string",
      "title": "Due Date"
    },
    "status": {
      "type": "string",
      "title": "Status",
      "enum": [
        "To Do",
        "In Progress",
        "Done",
        "Blocked"
      ],
      "default": "To Do"
    },
    "photos": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Photos"
    },
    "notes": {
      "type": "string",
      "title": "Notes"
    },
    "geo_lat": {
      "type": "number",
      "title": "Latitude"
    },
    "geo_lng": {
      "type": "number",
      "title": "Longitude"
    },
    "signature_url": {
      "type": "string",
      "title": "Client Signature"
    },
    "is_anomaly": {
      "type": "boolean",
      "title": "Anomaly Flagged"
    }
  },
  "required": [
    "title"
  ]
}