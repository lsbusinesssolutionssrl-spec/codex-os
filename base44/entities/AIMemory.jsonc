{
  "name": "AIMemory",
  "type": "object",
  "properties": {
    "company_id": {
      "type": "string",
      "title": "Company (Tenant)"
    },
    "memory_type": {
      "type": "string",
      "title": "Categoria Memoria",
      "enum": [
        "customer_preference",
        "project_history",
        "recurring_issue",
        "supplier_history",
        "operational_lesson",
        "estimate_outcome",
        "project_delay",
        "successful_solution",
        "recurring_failure",
        "pricing_pattern"
      ]
    },
    "title": {
      "type": "string",
      "title": "Titolo"
    },
    "content": {
      "type": "string",
      "title": "Contenuto"
    },
    "client_id": {
      "type": "string",
      "title": "Cliente Collegato"
    },
    "property_id": {
      "type": "string",
      "title": "Propriet\u00e0 Collegata"
    },
    "project_id": {
      "type": "string",
      "title": "Progetto Collegato"
    },
    "supplier_id": {
      "type": "string",
      "title": "Fornitore Collegato"
    },
    "estimate_id": {
      "type": "string",
      "title": "Preventivo Collegato"
    },
    "linked_entity_type": {
      "type": "string",
      "title": "Entit\u00e0 Primaria",
      "enum": [
        "client",
        "property",
        "project",
        "supplier",
        "estimate",
        "ticket",
        "tenant"
      ]
    },
    "linked_entity_id": {
      "type": "string",
      "title": "ID Entit\u00e0 Primaria"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "title": "Tags"
    },
    "relevance_score": {
      "type": "number",
      "title": "Rilevanza (0-1)",
      "minimum": 0,
      "maximum": 1,
      "default": 0.7
    },
    "confidence": {
      "type": "number",
      "title": "Confidenza (0-1)",
      "minimum": 0,
      "maximum": 1,
      "default": 0.8
    },
    "access_count": {
      "type": "number",
      "title": "Volte Usata",
      "default": 0
    },
    "last_accessed": {
      "type": "string",
      "title": "Ultimo Accesso"
    },
    "source": {
      "type": "string",
      "title": "Fonte",
      "enum": [
        "manual",
        "ai_extracted",
        "ai_chat",
        "project_close",
        "ticket_resolved",
        "estimate_accepted",
        "estimate_rejected"
      ]
    },
    "is_active": {
      "type": "boolean",
      "title": "Attivo",
      "default": true
    }
  },
  "required": [
    "memory_type",
    "content",
    "title"
  ]
}